{
  "name": "landing-page-fullstack",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev ./frontend",
    "dev:backend": "node --watch backend/src/server.js",
    "build": "next build ./frontend",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "next start ./frontend",
    "start:backend": "node backend/src/server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.4.9",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.511.0",
    "mongoose": "^8.14.2",
    "motion": "^12.23.24",
    "multer": "^2.0.2",
    "next": "^15.5.15",
    "nodemailer": "^7.0.5",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.8.3"
  }
}
